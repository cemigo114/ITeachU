# Environment Variables for ITeachU

# ====================
# BACKEND (server.js)
# ====================

# Anthropic API Key (REQUIRED for backend)
# Get your key from: https://console.anthropic.com/
# SECURITY: This should ONLY be set on the backend server, NEVER exposed to frontend
VITE_ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Server Port (optional, defaults to 3002)
PORT=3002

# Node Environment
NODE_ENV=development

# Google OAuth Client ID (REQUIRED for Google Sign-In)
# Get yours from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT Secret for signing auth tokens (use a strong random string in production)
JWT_SECRET=dev-secret

# PostgreSQL Database URL (optional for local dev — falls back to JSON files)
# For production: set automatically by Render via render.yaml
# For local dev with Postgres: postgresql://user:password@localhost:5432/iteachu
# DATABASE_URL=

# ====================
# FRONTEND (Vite)
# ====================

# Backend API URL (REQUIRED for production frontend)
# For local development: http://localhost:3002
# For production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:3002

# ====================
# DEPLOYMENT INSTRUCTIONS
# ====================

# Local Development:
# 1. Copy this file to \`.env\`
# 2. Fill in your VITE_ANTHROPIC_API_KEY
# 3. Run: npm run server (terminal 1)
# 4. Run: npm run dev (terminal 2)

# Production - Backend (Render):
# DATABASE_URL is auto-set by Render via render.yaml (linked to iteachu-db)
# Add these manually in Render's environment variables dashboard:
# - VITE_ANTHROPIC_API_KEY=sk-ant-xxxxx
# - PORT=3002
# - NODE_ENV=production

# Production - Frontend (Netlify):
# Add these in Netlify's environment variables:
# - VITE_API_URL=https://your-backend.onrender.com

# ====================
# SECURITY NOTES
# ====================

# ⚠️ NEVER commit the actual .env file to git
# ⚠️ NEVER expose VITE_ANTHROPIC_API_KEY to the frontend
# ⚠️ Use different API keys for development and production
# ⚠️ Rotate keys immediately if accidentally exposed
