generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id           String             @id @default(cuid())
  sessionId    String             @unique
  model        String
  systemPrompt String?            @db.Text
  status       String             @default("active")
  taskTitle    String?
  taskMetadata Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  messages   Message[]
  evaluation Evaluation?

  @@index([createdAt])
  @@index([status])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  sequenceNumber Int
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sequenceNumber])
}

model Evaluation {
  id                      String @id @default(cuid())
  conversationId          String @unique
  totalScore              Float
  conceptArticulation     Float
  logicCoherence          Float
  misconceptionCorrection Float
  cognitiveResilience     Float
  justifications          Json
  rawResponse             String? @db.Text
  evaluatorModel          String?
  createdAt               DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String
  googleId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  classes   ClassMember[]
}

model Class {
  id          String   @id @default(cuid())
  name        String
  gradeLevel  String
  subject     String   @default("Math")
  inviteCode  String   @unique
  teacherId   String
  createdAt   DateTime @default(now())
  members     ClassMember[]
}

model ClassMember {
  id      String @id @default(cuid())
  classId String
  userId  String
  role    String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([classId, userId])
  @@index([classId])
  @@index([userId])
}

model Assignment {
  id            String    @id @default(cuid())
  classId       String
  studentId     String
  taskId        String
  taskTitle     String
  status        String    @default("assigned")
  dueDate       DateTime?
  notes         String?
  sessionId     String?
  completedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([studentId])
  @@index([classId])
}
